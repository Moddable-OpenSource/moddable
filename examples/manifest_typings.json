{
	"build": {
		"TYPINGS": "$(MODDABLE)/typings"
	},
	"modules": {
		"*": [
			"$(TYPINGS)/*", "$(TYPINGS)/ble/*",
			"$(TYPINGS)/web/*"
		],
		"commodetto/*": [
			"$(TYPINGS)/commodetto/*"
		],
		"dns/*": [
			"$(TYPINGS)/dns/*"
		],
		"mc/*": [
			"$(TYPINGS)/mc/*"
		],
		"mod/*": [
			"$(TYPINGS)/mod/*"
		],
		"pins/*": [
			"$(TYPINGS)/pins/*"
		],
		"piu/*": [
			"$(TYPINGS)/piu/*"
		],
		"text/*": [
			"$(TYPINGS)/text/*"
		],
		"embedded:io/*": [
			"$(TYPINGS)/embedded_io/*"
		],
		"embedded:io/audio/*": [
			"$(TYPINGS)/embedded_io/audio/*"
		],
		"embedded:io/bluetoothle/*": [
			"$(TYPINGS)/embedded_io/ble/*"
		],
		"embedded:io/socket/*": [
			"$(TYPINGS)/embedded_io/socket/*"
		],
		"embedded:network/http/*": [
			"$(TYPINGS)/embedded_network/http/*"
		],
		"embedded:network/mqtt/*": [
			"$(TYPINGS)/embedded_network/mqtt/*"
		],
		"embedded:network/websocket/*": "$(TYPINGS)/embedded_network/websocket/*",
		"embedded:network/dns/resolver/*": [
			"$(TYPINGS)/embedded_network/dns/resolver/*"
		],
		"embedded:network/interface/*": [
			"$(TYPINGS)/embedded_network/interface/*"
		],
		"embedded:network/ntp/*": [
			"$(TYPINGS)/embedded_network/ntp/*"
		],
		"embedded:network/*": [
			"$(TYPINGS)/embedded_network/*"
		],
		"embedded:*": [
			"$(TYPINGS)/embedded/*"
		],
		"embedded:storage/*": [
			"$(TYPINGS)/embedded/storage/*"
		],
		"mqtt/js": [
			"$(TYPINGS)/mqtt/js"
		]
	}, 
	"platforms": {
		"pebble": {
			"modules": {
				"embedded:sensor/Accelerometer": "$(TYPINGS)/pebble/accelerometer",
				"embedded:sensor/Battery": "$(TYPINGS)/pebble/battery",
				"embedded:sensor/Compass": "$(TYPINGS)/pebble/compass",
				"embedded:sensor/Location": "$(TYPINGS)/pebble/location",
				"embedded:provider/builtin": "$(TYPINGS)/pebble/device",
				"pebble/button": "$(TYPINGS)/pebble/button",
				"pebble/dictation": "$(TYPINGS)/pebble/dictation",
				"pebble/message": "$(TYPINGS)/pebble/message",
				"pebble/vibes": "$(TYPINGS)/pebble/vibes",
				"pebble/wakeup": "$(TYPINGS)/pebble/wakeup"
			},
			"typescript": {
				"tsconfig": {
					"compilerOptions": {
						"types": [
							"$(TYPINGS)/pebble/global",
							"$(TYPINGS)/pebble/piu",
							"$(TYPINGS)/pebble/poco",
							"$(TYPINGS)/easing",
							"$(TYPINGS)/piu/MC",
							"$(TYPINGS)/piu/MC-types"
						]
					}
				}
			}
		},
		"...": {
			"modules": {
				"embedded:provider/*": [
					"$(TYPINGS)/embedded_provider/*"
				]
			}
		}
	}
}
