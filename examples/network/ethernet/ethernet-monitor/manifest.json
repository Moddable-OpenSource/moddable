{
	"include": [
		"$(MODDABLE)/examples/manifest_base.json",
		"$(MODDABLE)/modules/network/ethernet/manifest_net_ethernet.json",
		"$(MODULES)/crypt/tls.json",
		"$(MODULES)/network/http/manifest.json"
	],
	"modules": {
		"~": [
			"$(MODDABLE)/modules/network/ethernet/esp32/setup/ethernet",
			"$(BUILD)/devices/esp32/setup/network"
		],
		"*": [
			"./main",
			"$(MODULES)/network/http/*",
			"$(MODULES)/network/sntp/*"
		],
		"ethernet/connection": "./ethernetconnection"
	},
	"resources": {
		"*": [
			"$(MODULES)/crypt/data/ca176"
		]
	},
	"preload": [
		"http",
		"sntp"
	],
	"platforms": {
		"esp32": {},
		"...": {
			"error": "Platform not supported"
		}
	}
}
