{
	"include": [
		"$(MODDABLE)/examples/manifest_base.json",
		"$(MODDABLE)/examples/manifest_commodetto.json",
		"$(MODDABLE)/modules/base/debug/manifest.json",
		"$(MODDABLE)/modules/base/instrumentation/manifest.json",
		"$(MODDABLE)/modules/data/headers/manifest.json",
		"$(MODDABLE)/modules/data/qrcode/manifest.json",
		"$(MODDABLE)/modules/data/url/manifest.json",
		"$(MODDABLE)/modules/io/files/manifest.json",
		"$(MODDABLE)/modules/io/storage/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/global/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/display/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/poco/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/button/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/message/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/accelerometer/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/battery/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/compass/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/location/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/archive-resource/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/httpclient/manifest.json",
		"$(MODDABLE)/build/devices/pebble/modules/websocketclient/manifest.json",
		"$(MODDABLE)/modules/piu/Pebble/manifest.json"
	],
	"config": {
		"screen": "pebble/display",
		"touchCount": 0
	},
	"modules": {
		"*": [
			"./main",
			"./main-appinfo",
			"$(MODDABLE)/examples/io/storage/webstorage/webstorage.js",
			"$(MODDABLE)/examples/io/tcp/fetch/fetch.js",
			"$(MODDABLE)/examples/io/tcp/websocket/WebSocket.js"
		]
	},
	"preload": [
		"main",
		"webstorage",
		"fetch",
		"WebSocket"
	],
	"strip": [
		"Proxy",
		"Reflect",
		"Atomics",
		"WeakMap",
		"WeakSet",
		"BigInt",
		"eval",
		"Function",
		"Generator"
	]
}
