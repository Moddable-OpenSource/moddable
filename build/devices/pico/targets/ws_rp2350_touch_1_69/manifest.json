{
	"build": {
		"PICO_SUBCLASS": "rp2350"
	},
	"include": [
		"$(MODULES)/io/manifest.json",
		"$(MODULES)/drivers/st7789/manifest.json",
		"$(MODULES)/drivers/sensors/cst816s/manifest.json",
		"$(MODULES)/drivers/sensors/qmi8658/manifest.json",
		"$(MODULES)/drivers/peripherals/pcf85063/manifest.json",
		"$(MODULES)/drivers/led/manifest.json",
		"$(MODULES)/drivers/button/manifest.json",
		"$(MODULES)/pins/pwm/manifest.json"
	],
	"modules": {
		"setup/target": "./setup-target"
	},
	"preload": "setup/target",
	"config": {
		"screen": "ili9341",
		"backlight": 25,
		"brightness": 50
	},
	"defines": {
		"i2c": {
			"sda_pin": 6,
			"scl_pin": 7,
			"port": 1
		},
		"spi": {
			"mosi_pin": 11,
			"miso_pin": 12,
			"sck_pin": 10,
			"port": 1
		},
		"ili9341": {
			"width": 240,
			"height": 280,
			"cs_pin": 9,
			"dc_pin": 8,
			"rst_pin": 13,
			"spi_port": 1,
			"backlight_pin": 25,
			"backlight_on": 1,
			"flipx": true,
			"row_offset": 20
		}
	}
}
