{
	"include": [
		"$(MODULES)/drivers/button/manifest.json",
		"$(MODULES)/drivers/gc9a01/manifest.json",
		"$(MODULES)/drivers/neopixel/manifest.json"
	],
	"build":{
		"ESP32_SUBCLASS": "esp32c6"
	},
	"modules": {
		"setup/target": "./setup-target"
	},
	"preload": [
		"setup/target",
		"neopixel"
	],
	"config": {
		"screen": "ili9341",
		"led": {
			"pin": 8,
			"rainbow": true,
			"brightness": 16
		}
	},
	"creation": {
		"static": 0,
		"chunk": {
			"initial": 78848,
			"incremental": 0
		},
		"heap": {
			"initial": 4928,
			"incremental": 0
		},
		"stack": 512
	},
	"defines": {
		"i2c": {
			"sda_pin": 6,
			"scl_pin": 7
		},
		"spi": {
			"miso_pin":2,
			"mosi_pin":18,
			"sck_pin": 19
		},
		"ili9341": {
			"cs_pin": 16,
			"dc_pin": 17,
			"spi_port": 1
		}
	}
}
