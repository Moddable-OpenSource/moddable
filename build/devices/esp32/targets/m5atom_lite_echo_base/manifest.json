{
	"include": [
		"$(MODULES)/pins/smbus/manifest.json",
		"$(MODULES)/pins/digital/manifest.json",
		"$(MODULES)/pins/digital/monitor/manifest.json"
	],
	"build": {
		"UPLOAD_SPEED": "1500000",
		"DEBUGGER_SPEED": "1500000"
	},
	"modules": {
		"*": [
			"$(MODULES)/drivers/neopixel/*",
			"$(MODULES)/drivers/neopixel/esp32/*",
			"$(MODULES)/pins/audioin/*",
                        "$(MODULES)/pins/audioin/esp32/*",
			"../m5stack_fire/m5button"
		],
		"setup/target": "./setup-target",
		"pins/audioout": "$(MODULES)/pins/i2s/*",
                "pins/smbus": "$(MODULES)/pins/smbus/smbus"
	},
	"preload": [
		"pins/audioout",
		"audioin",
		"m5button",
		"neopixel",
		"setup/target"
	],
	"config": {
                "startupSound": "bflatmajor.maud",
		"es8311": {
			"volume": 160
		}
        },
	"resources": {
                "*": "$(MODDABLE)/examples/assets/sounds/bflatmajor"
        },
	"creation": {
		"static": 0,
		"chunk": {
			"initial": 78848,
			"incremental": 0
		},
		"heap": {
			"initial": 4928,
			"incremental": 0
		},
		"stack": 512
	},
	"defines": {
		"neopixel": {
			"length": 1,
			"pin": 27,
			"order": "#GRB",
			"rmt_channel": "RMT_CHANNEL_0"
		},
		"audioOut": {
                        "bitsPerSample": 16,
                        "numChannels": 1,
                        "sampleRate": 11025,
                        "volume_divider": 1,
                        "i2s": {
				"num": 1,
				"slot": "I2S_STD_SLOT_BOTH",
                                "bitsPerSample": 16,
                                "bck_pin": 33,
                                "lr_pin": 19,
                                "dataout_pin": 22
                        }
                },
                "audioIn": {
                        "sampleRate": 16000,
                        "bitsPerSample": 16,
                        "i2s": {
                                "num": 0,
                                "bck_pin": 33,
                                "lr_pin": 19,
                                "datain": 23
                        }
                }
	}
}
