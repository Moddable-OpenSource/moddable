{
	"build": {
		"SDKCONFIGPATH": "./sdkconfig",
		"PARTITIONS_FILE_FOR_TARGET": "./sdkconfig/partitions.csv",
		"ESP32_SUBCLASS": "esp32s3",
		"USE_USB": "2"
	},
	"include": [
		"$(MODULES)/io/manifest.json",
		"$(MODULES)/drivers/button/manifest.json",
		"$(MODULES)/drivers/st7789/manifest.json",
		"$(MODULES)/drivers/sensors/cst816s/manifest.json",
		"$(MODULES)/drivers/sensors/qmi8658/manifest.json",
		"$(MODULES)/drivers/peripherals/pcf85063/manifest.json",
		"$(MODULES)/pins/pwm/manifest.json"
	],
	"modules": {
		"setup/target": "./setup-target"
	},
	"preload": [
		"setup/target"
	],
	"config": {
		"screen": "ili9341",
		"backlight": 15,
			"brightness": 50,
		"xPWR_key": 36,
		"xPower": 35,
		"voltage": 1,
		"buzzer": 33,
		"rtc": {
			"int_pin": 41
		}
	},
	"creation": {
		"static": 0,
		"chunk": {
			"initial": 78848,
			"incremental": 0
		},
		"heap": {
			"initial": 4928,
			"incremental": 0
		},
		"stack": 512
	},
	"defines": {
		"i2c": {
			"sda_pin": 11,
			"scl_pin": 10
		},
		"spi": {
			"miso_pin": -1,
			"mosi_pin": 7,
			"sck_pin":  6
		},
		"ili9341": {
			"width": 240,
			"height": 280,
			"hz": 80000000,
			"cs_pin": 5,
			"dc_pin": 4,
			"rst_pin": 8,
			"spi_port": "SPI2_HOST",
			"row_offset": 20
		},
		"audioOut": {
			"bitsPerSample": 16,
			"channels": 1,
			"sampleRate": 24000,
			"streams": 1,
			"queueLength": 64,
			"volume_divider": 1,
			"i2s": {
				"PDM": 1,
				"pdm_pin": 33,
				"bitsPerSample": 16
			}
		}
	}
}
