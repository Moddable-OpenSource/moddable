{
	"build": {
		"EXPECTED_ESP_IDF": "v5.5.1"
	},
	"include": [
		"$(MODULES)/files/preference/manifest.json"
	],
	"modules": {
		"*": [
			"$(MODULES)/base/time/*",
			"$(MODULES)/base/time/esp/*",
			"$(MODULES)/base/timer/*",
			"$(MODULES)/base/timer/mc/*"
		]
	},
	"preload": [
		"time",
		"timer"
	],
	"platforms": {
		"esp32/*": {
			"include": "./targets/$(SUBPLATFORM)/manifest.json"
		}
	}
}
