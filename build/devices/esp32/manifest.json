{
	"build": {
		"EXPECTED_ESP_IDF": "v6.0"
	},
	"include": [
		"$(MODULES)/files/preference/manifest.json"
	],
	"modules": {
		"*": [
			"$(MODULES)/base/time/*",
			"$(MODULES)/base/time/esp/*",
			"$(MODULES)/base/timer/*",
			"$(MODULES)/base/timer/mc/*"
		]
	},
	"preload": [
		"time",
		"timer"
	],
	"platforms": {
		"esp32": {
			"dependency": [
				{ "idf": "esp_driver_gptimer" }
			]
		},
		"esp32/*": {
			"include": "$(SUBPLATFORMMANIFEST)",
			"dependency": [
				{ "idf": "esp_driver_gptimer" }
			]
		}
	}
}
