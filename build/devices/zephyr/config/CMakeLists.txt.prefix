list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsDataView.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsDate.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsDebug.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsError.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsFunction.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsGenerator.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsGlobal.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsJSON.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsLexical.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsLockdown.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsMapSet.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsMarshall.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsMath.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsMemory.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsModule.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsNumber.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsObject.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsPlatforms.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsProfile.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsPromise.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsProperty.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsProxy.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsRegExp.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsRun.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsScope.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsScript.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsSnapshot.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsSourceMap.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsString.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsSymbol.c)
