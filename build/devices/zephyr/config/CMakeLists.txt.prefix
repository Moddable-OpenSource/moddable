cmake_minimum_required(VERSION 3.20.0)
find_package(Zephyr REQUIRED HINTS $ENV{ZEPHYR_BASE})
project(moddable_lib)

# export all the flags used by zephyr
zephyr_get_include_directories_for_lang_as_string(       C includes)
zephyr_get_system_include_directories_for_lang_as_string(C system_includes)
zephyr_get_compile_definitions_for_lang_as_string(       C definitions)
zephyr_get_compile_options_for_lang_as_string(           C options)

if(DEFINED CMAKE_C_COMPILER_TARGET)
  set(target_flag "--target=${CMAKE_C_COMPILER_TARGET}")
endif()

set(FONTBM $ENV{FONTBM})

list(APPEND mOBJECTS $ENV{MODDABLE}/xs/platforms/mc/xsHosts.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/platforms/zephyr/xsHost.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/platforms/zephyr/xsPlatform.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsAPI.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsAll.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsArguments.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsArray.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsAtomics.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsBigInt.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsBoolean.c)
list(APPEND mOBJECTS $ENV{MODDABLE}/xs/sources/xsCode.c)
