{
	"build": {
	},
	"include": [
	],
	"modules": {
		"*": [
			"$(MODULES)/base/time/*",
			"$(MODULES)/base/time/zephyr/*",
			"$(MODULES)/base/timer/*",
			"$(MODULES)/base/timer/zephyr/*"
		]
	},
	"preload": [
		"time",
		"timer"
	],
	"creation": {
		"static": 32768,
		"chunk": {
			"initial": 8192
		},
		"heap": {
			"initial": 512
		},
		"stack": 256
},
	"platforms": {
		"zephyr/*": {
			"include": "$(BUILD)/devices/zephyr/targets/$(SUBPLATFORM)/manifest.json"
		}
	}
}
