{
	"modules": {
		"embedded:io/i2c": "$(IO)/i2c/i2c_async",
		"embedded:implementation/i2csync": "$(IO)/i2c/_i2c",
		"embedded:io/smbus": "$(IO)/i2c/smbus_async",
		"embedded:implementation/smbussync": "$(IO)/i2c/smbus",
		"*": [
			"$(MODULES)/io/common/builtinCommon",
			"$(MODULES)/io/i2c/$(PLATFORM)/*"
		]
	},
	"platforms": {
		"esp": {
		},
		"esp32": {
			"dependency": [
				{ "idf": "esp_driver_i2c" }
			]
		},
		"nrf52": {
		},
		"pico": {
		},
		"zephyr": {
		}
	},
	"preload": [
		"embedded:io/i2c",
		"embedded:implementation/i2csync",
		"embedded:io/smbus",
		"embedded:implementation/smbussync"
	]
}
