{
	"build": {
		"IO": "$(MODDABLE)/modules/io"
	},
	"platforms": {
		"mac": {},
		"win": {},
		"lin": {},
		"...": {
			"include": [
				"$(MODULES)/pins/spi/manifest.json"
			],
			"modules": {
				"*": [
					"$(MODULES)/io/common/builtinCommon",
					"$(MODULES)/io/spi/$(PLATFORM)/*"
				],
				"embedded:io/spi": "$(IO)/spi/spi"
			},
			"dependency": [
				{ "idf": "esp_driver_spi" }
			],
			"preload": [
				"embedded:io/spi"
			]
		}
	}
}
