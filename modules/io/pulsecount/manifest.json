				"*": [
					"$(MODULES)/io/common/builtinCommon"
				]
			}
		},
		"pico": {
			"modules": {
				"embedded:io/pulsecount": "$(IO)/pulsecount/$(PLATFORM)/*",
				"*": [
					"$(MODULES)/io/common/builtinCommon"
				]
			}
		}
	},
	"preload": [
		"embedded:io/pulsecount"
	]
