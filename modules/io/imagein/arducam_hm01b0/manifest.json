{
	"preload": [
		"embedded:io/image/in/camera"
	],
	"platforms": {
        "pico": {
            "include": [
                {   
                    "git":"https://github.com/mkellner/hm01b0-library-for-pico.git",
					"manifest": {
            			"modules": {
			                "*": [
								"./src/hm01b0.c",
								"./src/include/"
							]
						}
					}
				}
			],  
			"modules": {
                "embedded:io/image/in/camera": "./pico/*"
            }
        },
		"...": {
			"error": "Experimental TC53 IO modules"
		}
	}
}
