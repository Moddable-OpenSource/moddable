{
	"build": {
		"IO": "$(MODDABLE)/modules/io"
	},
	"include": [
		"$(IO)/analog/manifest.json",
		"$(IO)/audioout/manifest.json",
		"$(IO)/digital/manifest.json",
		"$(IO)/i2c/manifest.json"
		"$(IO)/pulsecount/manifest.json",
		"$(IO)/pwm/manifest.json",
		"$(IO)/serial/manifest.json",
		"$(IO)/spi/manifest.json"
	],
	"modules": {
		"*": [
			"$(IO)/common/builtinCommon",
			"$(MODULES)/pins/digital/pico/modGPIO"
		],
		"commodetto/Bitmap": "$(COMMODETTO)/commodettoBitmap",

		"system": "$(IO)/system/*"
	},
	"preload": [
		"embedded:*",
		"system"
	],
	"platforms": {
		"pico/*": {
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider"
			}
		},
		"pico": {
			"modules": {
				"embedded:provider/builtin": "$(IO)/host/$(PLATFORM)/provider"
			}
		},
		"...": {
			"error": "pico manifest"
		}
	}
}
