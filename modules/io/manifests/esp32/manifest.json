{
	"build": {
		"IO": "$(MODDABLE)/modules/io"
	},
	"include": [
		"$(MODULES)/pins/spi/manifest.json",
		"$(MODDABLE)/modules/io/pulsecount/manifest.json",
		"$(MODDABLE)/modules/io/pwm/manifest.json",
		"$(MODDABLE)/modules/io/pulsewidth/manifest.json",
		"$(MODDABLE)/modules/io/analog/manifest.json",
		"$(MODDABLE)/modules/io/digital/manifest.json"
	],
	"modules": {
		"*": [
			"$(IO)/common/builtinCommon",
			"$(IO)/i2c/$(PLATFORM)/*",
			"$(IO)/spi/$(PLATFORM)/*"
		],
		"commodetto/Bitmap": "$(COMMODETTO)/commodettoBitmap",

		"embedded:io/i2c": "$(IO)/i2c/i2c_async",
		"embedded:implementation/i2csync": "$(IO)/i2c/_i2c",
		"embedded:io/smbus": "$(IO)/i2c/smbus_async",
		"embedded:implementation/smbussync": "$(IO)/i2c/smbus",
		"embedded:io/serial": "$(IO)/serial/$(PLATFORM)/*",
		"embedded:io/spi": "$(IO)/spi/spi",

		"system": "$(IO)/system/*"
	},
	"preload": [
		"embedded:io/i2c",
		"embedded:implementation/i2csync",
		"embedded:io/smbus",
		"embedded:io/implementation/smbussync",
		"embedded:io/serial",
		"embedded:io/spi",
		"system"
	],
	"platforms": {
		"esp32": {
			"include": [
				"$(MODDABLE)/examples/manifest_net.json"
			],
			"modules": {
				"embedded:provider/builtin": "$(IO)/host/$(PLATFORM)/provider",

				"embedded:io/socket/tcp": "$(IO)/socket/lwip/tcp",
				"embedded:io/socket/udp": "$(IO)/socket/lwip/udp",
				"embedded:io/socket/listener": "$(IO)/socket/lwip/listener"
			},
			"preload": [
				"embedded:io/socket/tcp",
				"embedded:io/socket/udp",
				"embedded:io/socket/listener"
			]
		},
		"esp32/esp32c3": {
			"include": [
				"$(MODDABLE)/examples/manifest_net.json"
			],
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider",

				"embedded:io/socket/tcp": "$(IO)/socket/lwip/tcp",
				"embedded:io/socket/udp": "$(IO)/socket/lwip/udp",
				"embedded:io/socket/listener": "$(IO)/socket/lwip/listener"
			},
			"preload": [
				"embedded:io/socket/tcp",
				"embedded:io/socket/udp",
				"embedded:io/socket/listener"
			]
		},
		"esp32/esp32c3_cdc": {
			"include": [
				"$(MODDABLE)/examples/manifest_net.json"
			],
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider",

				"embedded:io/socket/tcp": "$(IO)/socket/lwip/tcp",
				"embedded:io/socket/udp": "$(IO)/socket/lwip/udp",
				"embedded:io/socket/listener": "$(IO)/socket/lwip/listener"
			},
			"preload": [
				"embedded:io/socket/tcp",
				"embedded:io/socket/udp",
				"embedded:io/socket/listener"
			]
		},
		"esp32/esp32c6": {
			"include": [
				"$(MODDABLE)/examples/manifest_net.json"
			],
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider",

				"embedded:io/socket/tcp": "$(IO)/socket/lwip/tcp",
				"embedded:io/socket/udp": "$(IO)/socket/lwip/udp",
				"embedded:io/socket/listener": "$(IO)/socket/lwip/listener"
			},
			"preload": [
				"embedded:io/socket/tcp",
				"embedded:io/socket/udp",
				"embedded:io/socket/listener"
			]
		},
		"esp32/esp32c6_cdc": {
			"include": [
				"$(MODDABLE)/examples/manifest_net.json"
			],
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider",

				"embedded:io/socket/tcp": "$(IO)/socket/lwip/tcp",
				"embedded:io/socket/udp": "$(IO)/socket/lwip/udp",
				"embedded:io/socket/listener": "$(IO)/socket/lwip/listener"
			},
			"preload": [
				"embedded:io/socket/tcp",
				"embedded:io/socket/udp",
				"embedded:io/socket/listener"
			]
		},
		"esp32/esp32h2": {
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider"
			}
		},
		"esp32/esp32h2_cdc": {
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider"
			}
		},
		"esp32/*": {
			"include": [
				"$(MODDABLE)/examples/manifest_net.json"
			],
			"modules": {
				"embedded:provider/builtin": "$(BUILD)/devices/$(PLATFORM)/targets/$(SUBPLATFORM)/host/provider",

				"embedded:io/socket/tcp": "$(IO)/socket/lwip/tcp",
				"embedded:io/socket/udp": "$(IO)/socket/lwip/udp",
				"embedded:io/socket/listener": "$(IO)/socket/lwip/listener"
			},
			"preload": [
				"embedded:io/socket/tcp",
				"embedded:io/socket/udp",
				"embedded:io/socket/listener"
			]
		},
		"...": {
			"error": "ESP32 manifest"
		}
	}
}
