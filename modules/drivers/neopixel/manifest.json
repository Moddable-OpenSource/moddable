{
	"modules": {
		"*": [
			"./*"
		]
	},
	"preload": "neopixel",
	"platforms": {
		"esp32": {
			"modules": {
				"*": "./esp32/*"
			},
			"dependency": [
				{ "idf": "esp_driver_rmt" }
			]
		},
		"pico": {
			"modules": {
				"*": [
					"./pico/*",
					"$(PICO_EXAMPLES_DIR)/pio/ws2812/ws2812.pio"
				]
			}
		}
	}
}
